# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/car_parts

# Port for the Express server
PORT=4000

# Comma-separated list of allowed CORS origins (frontend dev server)
CORS_ORIGIN=http://localhost:5173

# Secret used to sign the session cookie. REQUIRED in production.
# Generate a long random value, e.g.:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Do NOT commit a real secret to git — this placeholder is only an example.
SESSION_SECRET=change-me-to-a-long-random-string

# --- External barcode lookup (UPCitemdb by default) -------------------------
# Display name of the provider, shown in the UI ("Auto-filled from ...").
BARCODE_LOOKUP_PROVIDER=UPCitemdb
# Lookup endpoint. The free trial needs no API key (100 requests/day, shared).
# Trial:  https://api.upcitemdb.com/prod/trial/lookup
# Paid:   https://api.upcitemdb.com/prod/v1/lookup   (requires BARCODE_LOOKUP_API_KEY)
BARCODE_LOOKUP_URL=https://api.upcitemdb.com/prod/trial/lookup
# Optional API key. Leave blank to use the free trial endpoint above.
BARCODE_LOOKUP_API_KEY=
# Set to "false" to disable external lookups entirely (local DB check still runs).
BARCODE_LOOKUP_ENABLED=true
